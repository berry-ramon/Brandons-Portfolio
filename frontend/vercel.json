{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)\\.(ico|png|jpg|jpeg|svg|gif|webp|webmanifest|xml|txt|css|js|ts|tsx|json|woff|woff2|ttf|eot)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!.*\\.(?:ico|png|jpg|jpeg|svg|gif|webp|webmanifest|xml|txt|css|js|ts|tsx|json|woff|woff2|ttf|eot)$).*)",
      "destination": "/index.html"
    }
  ]
}
